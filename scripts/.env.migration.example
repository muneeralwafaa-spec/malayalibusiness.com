# ─────────────────────────────────────────────────────────────────────────────
# MalayaliBusiness — Migration Script Environment Variables
# Copy this file to .env.migration and fill in your values.
# NEVER commit .env.migration to git.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — use SERVICE ROLE key (not anon key).
# The anon key CANNOT bypass Row Level Security for inserts.
# Get it from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...

# Source WordPress site to scrape
SOURCE_URL=https://www.malayalibusiness.com

# System user that owns all migrated listings (created automatically if missing)
MIGRATION_USER_EMAIL=migration-bot@malayalibusiness.com
MIGRATION_USER_NAME=Migration Bot

# Optional: limit how many listings to import (useful for testing)
# IMPORT_LIMIT=50

# Delay between HTTP requests in milliseconds (be respectful to the server)
REQUEST_DELAY_MS=1000
